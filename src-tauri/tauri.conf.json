{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "marka.md",
  "version": "1.4.0",
  "identifier": "com.mattenarle.markamd",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "marka.md",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 420,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/mattenarle10/markamd/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0OUEwNzYyQ0I5N0YxQ0EKUldUSzhaZkxZZ2VhTk41OVJRRk5idHV0OGZVQURMUVJpQ0t1eXJTMjF6YzhEcXpuVVlDL1NFSUEK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Alternate"
      }
    ]
  }
}
